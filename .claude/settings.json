{
  "$comment": "Read-only permission model for the SRE agent. Layer 1: permissions.allow/deny lists below. Layer 2: block_mutations.py PreToolUse hook. Layer 3: read-only credentials. defaultMode 'default' applies standard judgment for anything not covered by the lists; the deny list + hook are the real enforcement.",
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Write",
      "Read",
      "Glob",
      "Grep",
      "TodoWrite",
      "Task",

      "Bash(kubectl get:*)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl logs:*)",
      "Bash(kubectl top:*)",
      "Bash(kubectl events:*)",
      "Bash(kubectl api-resources:*)",
      "Bash(kubectl explain:*)",

      "Bash(aws *describe*)",
      "Bash(aws *list*)",
      "Bash(aws *get*)",
      "Bash(aws logs filter-log-events:*)",
      "Bash(aws logs get-log-events:*)",
      "Bash(aws cloudwatch get-metric-data:*)",

      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",

      "mcp__pagerduty__get_incident",
      "mcp__pagerduty__list_incidents",
      "mcp__pagerduty__list_incident_notes",
      "mcp__pagerduty__add_note_to_incident",
      "mcp__pagerduty__get_service",
      "mcp__pagerduty__list_services",

      "mcp__grafana__*",
      "mcp__kubernetes__*",
      "mcp__aws__*",
      "mcp__github__*",
      "mcp__slack__post_message",
      "mcp__slack__postMessage"
    ],
    "deny": [
      "Write",
      "Edit",
      "MultiEdit",
      "NotebookEdit",

      "Bash(kubectl apply:*)",
      "Bash(kubectl delete:*)",
      "Bash(kubectl edit:*)",
      "Bash(kubectl scale:*)",
      "Bash(kubectl patch:*)",
      "Bash(kubectl rollout:*)",
      "Bash(kubectl cordon:*)",
      "Bash(kubectl drain:*)",
      "Bash(kubectl exec:*)",
      "Bash(kubectl replace:*)",
      "Bash(kubectl create:*)",
      "Bash(kubectl label:*)",
      "Bash(kubectl annotate:*)",
      "Bash(helm install:*)",
      "Bash(helm upgrade:*)",
      "Bash(helm uninstall:*)",
      "Bash(helm rollback:*)",

      "Bash(aws *create*)",
      "Bash(aws *update*)",
      "Bash(aws *delete*)",
      "Bash(aws *put*)",
      "Bash(aws *terminate*)",
      "Bash(aws *modify*)",
      "Bash(aws *reboot*)",
      "Bash(aws *start*)",
      "Bash(aws *stop*)",
      "Bash(aws *run-instances*)",
      "Bash(aws *set*)",
      "Bash(aws *attach*)",
      "Bash(aws *detach*)",

      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(git reset:*)",
      "Bash(git checkout:*)",
      "Bash(rm:*)",
      "Bash(sudo:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",

      "mcp__pagerduty__manage_incidents",
      "mcp__pagerduty__resolve_incident",
      "mcp__pagerduty__acknowledge_incident",
      "mcp__pagerduty__update_incident",
      "mcp__pagerduty__create_incident"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|MultiEdit|NotebookEdit|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/block_mutations.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/audit_log.py"
          }
        ]
      }
    ]
  }
}
