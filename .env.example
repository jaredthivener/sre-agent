# ─── Copy to .env for local development. NEVER commit .env. ───
#
# Auth model:
#   Local dev  — set tokens directly below (env vars win over Secrets Manager).
#   Production — set SECRETS_MANAGER_PREFIX=sre-agent and leave the token vars empty;
#                the agent fetches them from AWS Secrets Manager via OIDC/IRSA at startup.
#                Secrets are stored as plain strings under: sre-agent/<secret-suffix>
#                  sre-agent/anthropic-api-key
#                  sre-agent/pagerduty-api-token
#                  sre-agent/pagerduty-webhook-secret
#                  sre-agent/grafana-service-account-token
#                  sre-agent/github-token
#                  sre-agent/slack-bot-token

# ── Secrets Manager (production) ──────────────────────────────────────────────
# Leave empty for local dev (tokens below take precedence when set).
SECRETS_MANAGER_PREFIX=
AWS_SECRETS_REGION=us-east-1

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Orchestrator synthesises findings from all subagents → Opus (deep reasoning)
ORCHESTRATOR_MODEL=claude-opus-4-8
# All 7 specialist subagents (metrics/logs/traces/k8s/aws/deploy/scribe) → Sonnet (focused tasks)
# Also update model: in .claude/agents/*.md if you change this.
SUBAGENT_MODEL=claude-sonnet-4-6

# ── Webhook server ────────────────────────────────────────────────────────────
SRE_AGENT_HOST=0.0.0.0
SRE_AGENT_PORT=8080
# When 1, the agent investigates but logs the report instead of posting to PagerDuty/Slack.
DRY_RUN=1

# ── PagerDuty ─────────────────────────────────────────────────────────────────
# V3 webhook subscription signing secret (used to verify X-PagerDuty-Signature).
PAGERDUTY_WEBHOOK_SECRET=
# API token for the PagerDuty MCP server (read incidents + add notes only).
PAGERDUTY_API_TOKEN=
PAGERDUTY_USER_EMAIL=sre-agent@example.com

# ── Grafana (Prometheus / Loki / Tempo / alerting / OnCall / Sift) ────────────
GRAFANA_URL=https://your-org.grafana.net
# Service-account token scoped to VIEWER only.
GRAFANA_SERVICE_ACCOUNT_TOKEN=

# ── Kubernetes ────────────────────────────────────────────────────────────────
# Kubeconfig pointing at a READ-ONLY ServiceAccount / RBAC role.
# In-cluster (EKS + IRSA): omit — the pod uses its ServiceAccount token automatically.
KUBECONFIG=/var/run/sre-agent/kubeconfig

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# Local dev only: set a read-only profile (e.g. ReadOnlyAccess).
# Production: omit — OIDC/IRSA provides credentials via AWS_ROLE_ARN + AWS_WEB_IDENTITY_TOKEN_FILE.
# AWS_PROFILE=sre-agent-readonly

# ── GitHub ────────────────────────────────────────────────────────────────────
# Fine-grained PAT with read-only repo scope (for deploys / PRs / diffs).
GITHUB_TOKEN=

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_INCIDENT_CHANNEL=#incidents
